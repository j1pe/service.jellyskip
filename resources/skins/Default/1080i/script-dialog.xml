<?xml version="1.0" encoding="UTF-8"?>
<window id="9999">
    <defaultcontrol always="true">2101</defaultcontrol>
    <animation effect="fade" start="0" end="100" time="300">WindowOpen</animation>
    <animation effect="fade" start="100" end="0" time="300">WindowClose</animation>
    <controls>
        <control type="group" id="9001">
            <animation type="WindowOpen" reversible="false">
                <effect type="slide" start="0,400" end="0,0" tween="cubic" easing="out" delay="0" time="450" reversible="false"/>
                <effect type="fade" start="0" end="100" delay="0" time="350" reversible="false"/>
            </animation>
            <animation type="WindowClose" reversible="false">
                <effect type="slide" start="0,0" end="0,400" tween="cubic" easing="out" delay="0" time="450" reversible="false"/>
                <effect type="fade" start="100" end="0" delay="0" time="350" reversible="false"/>
            </animation>
            
            <right>100</right>
            <bottom>150</bottom>
            <width>1000</width> 
            <height>64</height>
            
            <control type="grouplist">
                <orientation>horizontal</orientation>
                <itemgap>0</itemgap>
                <align>right</align>
                <width>1000</width>
                <height>64</height>
                
                <!-- Skip Intro/Next -->
                <control type="button" id="2101">
                    <description>Skip Segment Button</description>
                    <width>auto</width>
                    <height>64</height>
                    <aligny>center</aligny>
                    <align>center</align>
                    <label/>
                    <font>font12</font>
                    <textcolor>FFFFFFFF</textcolor>
                    <focusedcolor>FFFFFFFF</focusedcolor>
                    <shadowcolor>FF000000</shadowcolor>
                    
                    <textoffsetx>40</textoffsetx>
                    <textoffsety>0</textoffsety>
                    
                    <texturenofocus border="20" colordiffuse="A0000000">buttons/dialogbutton-nofo.png</texturenofocus>
                    <texturefocus border="20" colordiffuse="button_focus">buttons/dialogbutton-fo.png</texturefocus>
                    
                    <onright>2102</onright>
                    <onleft>2102</onleft>
                </control>

                <!-- EXIT -->
                <control type="button" id="2102">
                    <description>Quit Button</description>
                    <width>auto</width>
                    <height>64</height>
                    <aligny>center</aligny>
                    <align>center</align>
                    <label>Quitter</label>
                    <font>font12</font>
                    <textcolor>FFFFFFFF</textcolor>
                    <focusedcolor>FFFFFFFF</focusedcolor>
                    <shadowcolor>FF000000</shadowcolor>
                    
                    <textoffsetx>40</textoffsetx>
                    <textoffsety>0</textoffsety>
                    
                    <texturenofocus border="20" colordiffuse="A0000000">buttons/dialogbutton-nofo.png</texturenofocus>
                    <texturefocus border="20" colordiffuse="button_focus">buttons/dialogbutton-fo.png</texturefocus>
                    
                    <onright>2101</onright>
                    <onleft>2101</onleft>
                </control>
            </control>
        </control>
    </controls>
</window>